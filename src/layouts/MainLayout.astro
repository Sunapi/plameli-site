---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Пламели Финанс | Счетоводни и данъчни услуги в София",
  description = "Професионални счетоводни услуги, данъчни консултации, ТРЗ и бизнес подкрепа в София. Консултации на български, украински и руски език.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
