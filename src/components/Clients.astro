---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { siteData, type Locale } from "../i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = siteData[locale].clients;

const iconMap = {
  building: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 21V7a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v14M2 21h20M9 9h2M9 13h2M13 9h2M13 13h2M10 21v-4h4v4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  briefcase: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 6V4h6v2M3 9h18v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Zm0 0a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2M10 13h4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  rocket: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 4c3 1 5 3 6 6-2.2 4.1-5.9 7.8-10 10-3-1-5-3-6-6 2.2-4.1 5.9-7.8 10-10Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M10 14 4 20M15 9h.01" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  user: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM5 20a7 7 0 0 1 14 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  home: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 10.5 12 4l8 6.5V20a1 1 0 0 1-1 1h-4v-6H9v6H5a1 1 0 0 1-1-1v-9.5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
};
---

<Section size="base" class="bg-[var(--color-surface-muted)]">
  <Container>
    <SectionHeading class="mb-10" align="center" eyebrow={data.eyebrow} title={data.title} description={data.description} />
    <Grid class="gap-6 sm:grid-cols-2 lg:grid-cols-5">
      {
        data.items.map((client) => (
          <Card as="article" class="flex h-full flex-col items-center text-center">
            <span class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] [&_svg]:h-8 [&_svg]:w-8">
              <Fragment set:html={iconMap[client.icon]} />
            </span>
            <h3 class="font-semibold text-[var(--color-text)]">{client.title}</h3>
            <p class="mt-2 flex-grow text-sm leading-relaxed text-[var(--color-text-muted)]">{client.description}</p>
          </Card>
        ))
      }
    </Grid>
  </Container>
</Section>
