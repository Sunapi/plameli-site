---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";

const iconMap = {
  spark: `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="m12 3 1.8 4.8L18.5 9l-4.7 1.2L12 15l-1.8-4.8L5.5 9l4.7-1.2L12 3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
    </svg>
  `,
  shield: `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 3 5 6v6c0 4.2 2.7 7.7 7 9 4.3-1.3 7-4.8 7-9V6l-7-3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
    </svg>
  `,
  compass: `
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8"/>
      <path d="m15.5 8.5-2.5 6-6 2.5 2.5-6 6-2.5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
    </svg>
  `,
};

const testimonials = [
  {
    icon: "spark",
    content: "Желанието ни да предоставяме услуги с най-високо качество и стремежът към доверени, честни и коректни взаимоотношения са в основата на фирмената ни философия.",
    author: "Фирмена философия",
    role: "Пламели Финанс",
  },
  {
    icon: "shield",
    content: "Стремим се да съхраняваме спечеленото доверие, следвайки неизменната цел за компетентно и надеждно удовлетворяване на специфичните потребности на нашите клиенти.",
    author: "Подход към клиента",
    role: "Пламели Финанс",
  },
  {
    icon: "compass",
    content: "Нашият стремеж е да бъдем партньори на клиентите си, да разбираме техните проблеми и нужди и да предлагаме правилни и коректни решения в дългосрочен план.",
    author: "Мисия",
    role: "Пламели Финанс",
  },
];
---

<Section size="base" class="bg-[var(--color-surface-muted)]">
  <Container>
    <SectionHeading
      class="mb-10"
      align="center"
      eyebrow="Философия"
      title="Какво стои зад работата на Пламели Финанс"
      description="Този блок е адаптиран по текста от страницата „За нас“ и замества предишните примерни отзиви с реални принципи и послания на компанията."
    />

    <Grid class="gap-8 md:grid-cols-3">
      {
        testimonials.map((testimonial) => (
          <Card as="article" class="flex h-full flex-col gap-6 rounded-2xl">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] [&_svg]:h-5 [&_svg]:w-5">
              <Fragment set:html={iconMap[testimonial.icon]} />
            </span>
            <blockquote class="flex-grow leading-relaxed text-[var(--color-text)]">{testimonial.content}</blockquote>
            <footer class="border-t border-[var(--color-border)] pt-6">
              <p class="font-semibold text-[var(--color-text)]">{testimonial.author}</p>
              <p class="text-sm text-[var(--color-text-muted)]">{testimonial.role}</p>
            </footer>
          </Card>
        ))
      }
    </Grid>
  </Container>
</Section>
