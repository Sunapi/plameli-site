---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { siteData, type Locale } from "../i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = siteData[locale].testimonials;

const iconMap = {
  spark: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 1.8 4.8L18.5 9l-4.7 1.2L12 15l-1.8-4.8L5.5 9l4.7-1.2L12 3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 5 6v6c0 4.2 2.7 7.7 7 9 4.3-1.3 7-4.8 7-9V6l-7-3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
  compass: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="m15.5 8.5-2.5 6-6 2.5 2.5-6 6-2.5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
};
---

<Section size="base" class="bg-[var(--color-surface-muted)]">
  <Container>
    <SectionHeading class="mb-10" align="center" eyebrow={data.eyebrow} title={data.title} description={data.description} />
    <Grid class="gap-8 md:grid-cols-3">
      {
        data.items.map((item) => (
          <Card as="article" class="flex h-full flex-col gap-6 rounded-2xl">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[var(--color-primary)]/10 text-[var(--color-primary)] [&_svg]:h-5 [&_svg]:w-5">
              <Fragment set:html={iconMap[item.icon]} />
            </span>
            <blockquote class="flex-grow leading-relaxed text-[var(--color-text)]">{item.content}</blockquote>
            <footer class="border-t border-[var(--color-border)] pt-6">
              <p class="font-semibold text-[var(--color-text)]">{item.author}</p>
              <p class="text-sm text-[var(--color-text-muted)]">{item.role}</p>
            </footer>
          </Card>
        ))
      }
    </Grid>
  </Container>
</Section>
