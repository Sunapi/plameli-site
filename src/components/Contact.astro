---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";

const benefits = [
  "Консултации на български, украински и руски език",
  "Коректни и надеждни решения според конкретния казус",
  "Дългосрочно партньорство, конфиденциалност и високи стандарти",
];
---

<Section id="contact" size="base" class="pt-14 pb-16 lg:pt-18 lg:pb-18">
  <Container>
    <Grid class="items-start gap-10 lg:grid-cols-2 lg:gap-12">
      <div>
        <SectionHeading
          eyebrow="Контакти"
          title="Осигурете си сигурност и спокойствие"
          titleClass="sm:text-4xl"
        />
        <p class="mt-6 text-lg leading-relaxed text-[var(--color-text-muted)]">
          Целта на Пламели Финанс е да ви спести ценно време, средства и усилия,
          за да можете спокойно да развивате бизнеса си и да постигате целите си.
        </p>

        <div class="mt-8 space-y-4">
          {
            benefits.map((benefit) => (
              <div class="flex items-start gap-3">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                <span class="text-[var(--color-text)]">{benefit}</span>
              </div>
            ))
          }
        </div>

        <Card as="aside" class="mt-10 bg-[var(--color-surface-muted)] p-6">
          <p class="text-sm text-[var(--color-text-muted)]">Свържете се директно с нас</p>
          <a class="mt-1 block text-2xl font-semibold text-[var(--color-text)] transition hover:text-[var(--color-primary)]" href="tel:+359886843640">
            +359 886 843 640
          </a>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">+359 242 327 32</p>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">гр. София, ул. Рачо Димчев 1А, ет.1, ап.2</p>
        </Card>
      </div>

      <Card as="div" id="contact-form" class="rounded-2xl p-8 shadow-lg lg:p-10">
        <h3 class="mb-6 text-xl font-semibold text-[var(--color-text)]">Изпратете запитване</h3>
        <form class="space-y-5" action="https://formsubmit.co/apichenok@gmail.com" method="POST">
          <input type="hidden" name="_subject" value="Ново запитване от сайта Пламели Финанс" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2">
              <span>Име и фамилия</span>
              <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="text" name="name" placeholder="Вашето име" required data-label="Име и фамилия" />
            </label>
            <label class="grid gap-2">
              <span>Име на компания</span>
              <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="text" name="company" placeholder="Вашата компания" />
            </label>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2">
              <span>Имейл</span>
              <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="email" name="email" placeholder="email@example.com" required data-label="Имейл" />
            </label>
            <label class="grid gap-2">
              <span>Телефон</span>
              <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="tel" name="phone" placeholder="+359..." />
            </label>
          </div>

          <label class="grid gap-2">
            <span>Интересуващи услуги</span>
            <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="text" name="services" placeholder="напр. счетоводно обслужване, пейрол, регистрация на фирма" />
          </label>

          <label class="grid gap-2">
            <span>Съобщение</span>
            <textarea class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" name="message" rows="4" placeholder="Разкажете ни повече за вашия бизнес и нужди..."></textarea>
          </label>

          <button class="inline-flex w-full items-center justify-center rounded-full bg-[var(--color-primary)] px-6 py-3 font-semibold text-white transition hover:bg-[var(--color-primary-dark)]" type="submit">
            Изпрати запитване
          </button>
          <p class="text-center text-xs text-[var(--color-text-muted)]">
            С изпращането се съгласявате с нашата политика за поверителност. Ние уважаваме вашите данни.
          </p>
        </form>
      </Card>
    </Grid>
  </Container>
</Section>

<script>
  const messages = {
    valueMissing: (label) => `Моля, попълнете полето "${label}".`,
    typeMismatch: {
      email: "Моля, въведете валиден имейл адрес.",
      url: "Моля, въведете валиден адрес.",
    },
  };

  const form = document.querySelector("#contact-form form");

  if (form) {
    const controls = form.querySelectorAll("input, textarea");

    controls.forEach((control) => {
      control.addEventListener("input", () => {
        control.setCustomValidity("");
      });

      control.addEventListener("invalid", () => {
        const label = control.dataset.label || "това поле";
        const validity = control.validity;

        if (validity.valueMissing) {
          control.setCustomValidity(messages.valueMissing(label));
          return;
        }

        if (validity.typeMismatch) {
          control.setCustomValidity(messages.typeMismatch[control.type] || "Моля, въведете валидна стойност.");
          return;
        }

        control.setCustomValidity("Моля, проверете въведената стойност.");
      });
    });
  }
</script>
