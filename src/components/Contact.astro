---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { sharedContact, siteData, type Locale } from "../i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = siteData[locale].contact;
---

<Section id="contact" size="base" class="pt-14 pb-16 lg:pt-18 lg:pb-18">
  <Container>
    <Grid class="items-start gap-10 lg:grid-cols-2 lg:gap-12">
      <div>
        <SectionHeading eyebrow={data.eyebrow} title={data.title} titleClass="sm:text-4xl" />
        <p class="mt-6 text-lg leading-relaxed text-[var(--color-text-muted)]">{data.description}</p>

        <div class="mt-8 space-y-4">
          {
            data.benefits.map((benefit) => (
              <div class="flex items-start gap-3">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-accent)]"></span>
                <span class="text-[var(--color-text)]">{benefit}</span>
              </div>
            ))
          }
        </div>

        <Card as="aside" class="mt-10 bg-[var(--color-surface-muted)] p-6">
          <p class="text-sm text-[var(--color-text-muted)]">{data.directLabel}</p>
          <a class="mt-1 block text-2xl font-semibold text-[var(--color-text)] transition hover:text-[var(--color-primary)]" href={`tel:${sharedContact.phones[0].replace(/\s+/g, "")}`}>
            {sharedContact.phones[0]}
          </a>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">{sharedContact.phones[1]}</p>
          <p class="mt-2 text-sm text-[var(--color-text-muted)]">{data.address}</p>
        </Card>
      </div>

      <Card as="div" id="contact-form" class="rounded-2xl p-8 shadow-lg lg:p-10">
        <h3 class="mb-6 text-xl font-semibold text-[var(--color-text)]">{data.formTitle}</h3>
        <form class="space-y-5" action="https://formsubmit.co/apichenok@gmail.com" method="POST" data-locale={locale}>
          <input type="hidden" name="_subject" value={data.subject} />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2">
              <span>{data.fields.name}</span>
              <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="text" name="name" placeholder={data.fields.namePlaceholder} required data-label={data.fields.name} />
            </label>
            <label class="grid gap-2">
              <span>{data.fields.company}</span>
              <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="text" name="company" placeholder={data.fields.companyPlaceholder} />
            </label>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <label class="grid gap-2">
              <span>{data.fields.email}</span>
              <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="email" name="email" placeholder={data.fields.emailPlaceholder} required data-label={data.fields.email} />
            </label>
            <label class="grid gap-2">
              <span>{data.fields.phone}</span>
              <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="tel" name="phone" placeholder={data.fields.phonePlaceholder} />
            </label>
          </div>

          <label class="grid gap-2">
            <span>{data.fields.services}</span>
            <input class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" type="text" name="services" placeholder={data.fields.servicesPlaceholder} />
          </label>

          <label class="grid gap-2">
            <span>{data.fields.message}</span>
            <textarea class="rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]/45 focus:ring-2 focus:ring-[var(--color-primary)]/20" name="message" rows="4" placeholder={data.fields.messagePlaceholder}></textarea>
          </label>

          <button class="inline-flex w-full items-center justify-center rounded-full bg-[var(--color-primary)] px-6 py-3 font-semibold text-white transition hover:bg-[var(--color-primary-dark)]" type="submit">
            {data.submit}
          </button>
          <p class="text-center text-xs text-[var(--color-text-muted)]">{data.privacy}</p>
        </form>
      </Card>
    </Grid>
  </Container>
</Section>

<script define:vars={{ validations: Object.fromEntries(Object.entries(siteData).map(([key, value]) => [key, value.contact.validation])) }}>
  const form = document.querySelector("#contact-form form");

  if (form instanceof HTMLFormElement) {
    const locale = form.dataset.locale || "bg";
    const messages = validations[locale] || validations.bg;
    const controls = form.querySelectorAll("input, textarea");

    controls.forEach((control) => {
      control.addEventListener("input", () => {
        control.setCustomValidity("");
      });

      control.addEventListener("invalid", () => {
        const label = control.dataset.label || messages.fallbackField;
        const validity = control.validity;

        if (validity.valueMissing) {
          control.setCustomValidity(messages.fillField.replace("{label}", label));
          return;
        }

        if (validity.typeMismatch) {
          control.setCustomValidity(control.type === "email" ? messages.invalidEmail : messages.invalidUrl);
          return;
        }

        control.setCustomValidity(messages.invalidValue);
      });
    });
  }
</script>
