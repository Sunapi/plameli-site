---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { siteData, type Locale } from "../i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = siteData[locale].languages;
---

<Section size="base" class="bg-gradient-to-br from-[var(--color-primary-dark)] to-[var(--color-primary)] text-[#fff7f3]">
  <Container>
    <Grid class="items-center gap-10 lg:grid-cols-2 lg:gap-12">
      <SectionHeading class="max-w-xl" eyebrow={data.eyebrow} title={data.title} description={data.description} invert={true} />

      <Grid class="gap-4 sm:grid-cols-3">
        {
          data.items.map((language) => (
            <Card as="article" class="min-w-0 border-white/20 bg-white/10 p-6 backdrop-blur-sm">
              {language.flag === "bg" && (
                <span class="inline-flex h-6 w-8 flex-col overflow-hidden rounded-[0.3rem] border border-white/25">
                  <span class="h-1/3 w-full bg-white"></span>
                  <span class="h-1/3 w-full bg-[#1faa59]"></span>
                  <span class="h-1/3 w-full bg-[#d62612]"></span>
                </span>
              )}
              {language.flag === "ua" && (
                <span class="inline-flex h-6 w-8 flex-col overflow-hidden rounded-[0.3rem] border border-white/25">
                  <span class="h-1/2 w-full bg-[#1f6fe5]"></span>
                  <span class="h-1/2 w-full bg-[#ffd84d]"></span>
                </span>
              )}
              {!language.flag && <p class="[font-family:'Playfair_Display',serif] text-3xl font-medium text-white">{language.code}</p>}
              <h3 class="mt-3 text-lg font-medium text-white">{language.name}</h3>
              <p class="mt-2 text-sm leading-relaxed text-white/70">{language.description}</p>
            </Card>
          ))
        }
      </Grid>
    </Grid>
  </Container>
</Section>
