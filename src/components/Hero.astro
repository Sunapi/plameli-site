---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import Badge from "./ui/Badge.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import StatItem from "./ui/StatItem.astro";
import { localePaths, siteData, type Locale } from "../i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = siteData[locale].hero;
const basePath = localePaths[locale];

const iconMap = {
  calendar: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2v3M17 2v3M3 9h18M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  globe: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21c4.971 0 9-4.029 9-9s-4.029-9-9-9-9 4.029-9 9 4.029 9 9 9Z" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M3 12h18M12 3c2.7 2.4 4.2 5.4 4.2 9S14.7 18.6 12 21M12 3C9.3 5.4 7.8 8.4 7.8 12s1.5 6.6 4.2 9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  stack: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 4 8 4-8 4-8-4 8-4Zm8 8-8 4-8-4m16 4-8 4-8-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  ledger: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4h12a2 2 0 0 1 2 2v12H8a2 2 0 0 0-2 2V4Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M8 20a2 2 0 0 1-2-2V6a2 2 0 0 0-2-2M10 8h6M10 12h6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  scale: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4v16M6 7h12M9 20h6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="m7 7-3 5h6l-3-5Zm10 0-3 5h6l-3-5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
  users: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2M9.5 11a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Zm8.5 10v-2a4 4 0 0 0-3-3.87M15.5 4.13a3.5 3.5 0 0 1 0 6.74" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
};
---

<Section size="tight" class="relative overflow-hidden bg-[var(--color-background)] pt-10 pb-10 lg:pt-14 lg:pb-14">
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_right,transparent_0%,transparent_49%,rgba(228,218,203,0.55)_49%,rgba(228,218,203,0.55)_51%,transparent_51%,transparent_100%)] bg-[length:120px_100%] opacity-30"></div>
  <Container class="relative">
    <div class="grid grid-cols-12 items-stretch gap-8 lg:gap-12">
      <div class="col-span-12 flex flex-col justify-center lg:col-span-6">
        <Badge as="p" class="px-4 py-1.5 text-sm">
          <span class="h-2 w-2 rounded-full bg-[var(--color-accent)]"></span>
          {data.badge}
        </Badge>

        <SectionHeading
          class="mt-6"
          titleAs="h1"
          title={data.title}
          description={data.description}
          titleClass="mt-0 max-w-xl text-4xl font-semibold leading-tight lg:text-5xl"
          descriptionClass="mt-6 max-w-lg text-lg leading-relaxed text-[var(--color-text-muted)]"
        />

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a class="inline-flex items-center justify-center rounded-xl bg-orange-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-orange-600" href={`${basePath}#contact`}>
            {data.primaryCta}
          </a>
          <a class="inline-flex items-center justify-center rounded-xl border border-neutral-300 bg-white px-6 py-3 text-sm font-semibold text-[var(--color-text)] transition hover:bg-neutral-100" href={`${basePath}#services`}>
            {data.secondaryCta}
          </a>
        </div>

        <Grid class="mt-8 max-w-xl grid-cols-3 gap-6 border-t border-[var(--color-border)] pt-6">
          {
            data.stats.map((stat) => (
              <StatItem value={stat.value} label={stat.label}>
                <Fragment slot="icon" set:html={iconMap[stat.icon]} />
              </StatItem>
            ))
          }
        </Grid>
      </div>

      <div class="col-span-12 lg:col-span-6">
        <div class="relative max-w-xl lg:ml-auto lg:mt-6">
          <div class="relative min-h-[26rem] overflow-hidden rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-surface-muted)] shadow-[var(--shadow-soft)] lg:h-[33.5rem] lg:min-h-0">
            <div class="absolute inset-0 bg-gradient-to-tr from-[rgba(243,88,40,0.08)] via-transparent to-[rgba(255,255,255,0.12)]"></div>
            <img
              class="h-full w-full object-cover object-center"
              src="/hero-accounting.jpg"
              alt=""
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[rgba(31,24,21,0.18)] via-transparent to-[rgba(31,24,21,0.04)]"></div>
            <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6">
              <div class="ml-auto grid max-w-[90%] grid-cols-1 gap-4 sm:grid-cols-2">
              {
                data.cards.map((card, index) => (
                  <Card
                    as="article"
                    class:list={[
                      "border border-neutral-200 bg-white/96 p-5 shadow-sm backdrop-blur",
                      index === 2 && "sm:col-span-2 sm:max-w-[76%]",
                    ]}
                  >
                    <div class="flex items-start gap-3">
                      <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-orange-100 text-[var(--color-primary)] [&_svg]:h-5 [&_svg]:w-5">
                        <Fragment set:html={iconMap[card.icon]} />
                      </span>
                      <div class="min-w-0 pr-4">
                        <p class="text-base font-medium leading-snug text-[var(--color-text)]">{card.title}</p>
                        <p class="mt-1 text-sm leading-relaxed text-[var(--color-text-muted)]">{card.text}</p>
                      </div>
                    </div>
                  </Card>
                ))
              }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>
