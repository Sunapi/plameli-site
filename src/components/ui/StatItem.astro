---
interface Props {
  value: string;
  label: string;
  class?: string;
}

const { value, label, class: className = "" } = Astro.props;
---

<div class:list={["flex items-center gap-3", className]}>
  <div class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[var(--color-surface-muted)] text-[var(--color-primary)] [&_svg]:h-5 [&_svg]:w-5">
    <slot name="icon" />
  </div>
  <div>
    <p class="text-2xl font-semibold text-[var(--color-text)]">{value}</p>
    <p class="text-sm text-[var(--color-text-muted)]">{label}</p>
  </div>
</div>
