---
import Container from "./ui/Container.astro";
import { localeNames, localePaths, sharedContact, siteData, type Locale } from "../i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = siteData[locale];
const activePath = localePaths[locale];

const languages = [
  { code: "bg" as const, flag: "bg" as const },
  { code: "ua" as const, flag: "ua" as const },
  { code: "ru" as const },
];
const currentLanguage = languages.find((language) => language.code === locale) ?? languages[0];
---

<header class="sticky top-0 z-50 border-b border-[rgba(228,218,203,0.7)] bg-[rgba(251,248,242,0.9)] backdrop-blur-[18px]">
  <Container class="flex min-h-[4rem] items-center justify-between gap-4 lg:min-h-[4.25rem]">
    <a class="inline-flex items-center gap-3" href={activePath}>
      <img class="h-9 w-9 object-contain lg:h-10 lg:w-10" src="/plameli-logo.png" alt={data.header.brand} />
      <span class="text-[0.98rem] font-semibold tracking-tight text-[var(--color-primary)] lg:text-base">{data.header.brand}</span>
    </a>

    <nav class="hidden grid-cols-5 gap-2 lg:grid" aria-label="Primary">
      {
        data.header.navigation.map((item) => (
          <a class="inline-flex min-w-[4.9rem] justify-center text-center text-[0.95rem] text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]" href={`${activePath}${item.href}`}>
            {item.name}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <details class="relative">
        <summary class="inline-flex min-h-[2.1rem] min-w-[4.5rem] list-none items-center justify-center gap-2 rounded-full border border-[rgba(228,218,203,0.7)] bg-white px-2.5 text-[0.78rem] font-semibold text-[var(--color-text-muted)] shadow-sm">
          {currentLanguage.flag === "bg" && (
            <span class="inline-flex h-[1.55rem] w-[2.45rem] shrink-0 flex-col overflow-hidden rounded-full border border-black/5">
              <span class="h-1/3 w-full bg-white"></span>
              <span class="h-1/3 w-full bg-[#1faa59]"></span>
              <span class="h-1/3 w-full bg-[#d62612]"></span>
            </span>
          )}
          {currentLanguage.flag === "ua" && (
            <span class="inline-flex h-[1.55rem] w-[2.45rem] shrink-0 flex-col overflow-hidden rounded-full border border-black/5">
              <span class="h-1/2 w-full bg-[#1f6fe5]"></span>
              <span class="h-1/2 w-full bg-[#ffd84d]"></span>
            </span>
          )}
          {!currentLanguage.flag && <span>{locale.toUpperCase()}</span>}
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M5.5 7.5 10 12l4.5-4.5" />
          </svg>
        </summary>
        <div class="absolute right-0 top-[calc(100%+0.65rem)] min-w-[9rem] rounded-2xl border border-[var(--color-border)] bg-white p-2 shadow-[var(--shadow-card)]">
          <div class="grid gap-1" aria-label="Available languages">
            {
              languages.map((language) => {
                const isActive = language.code === locale;
                return (
                  <a
                    class:list={[
                      "inline-flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-[var(--color-text-muted)] transition hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-text)]",
                      isActive && "bg-[var(--color-surface-muted)] text-[var(--color-text)]",
                    ]}
                    href={localePaths[language.code]}
                    aria-label={localeNames[language.code]}
                  >
                    {language.flag === "bg" && (
                      <span class="inline-flex h-4 w-6 shrink-0 flex-col overflow-hidden rounded-sm border border-black/5">
                        <span class="h-1/3 w-full bg-white"></span>
                        <span class="h-1/3 w-full bg-[#1faa59]"></span>
                        <span class="h-1/3 w-full bg-[#d62612]"></span>
                      </span>
                    )}
                    {language.flag === "ua" && (
                      <span class="inline-flex h-4 w-6 shrink-0 flex-col overflow-hidden rounded-sm border border-black/5">
                        <span class="h-1/2 w-full bg-[#1f6fe5]"></span>
                        <span class="h-1/2 w-full bg-[#ffd84d]"></span>
                      </span>
                    )}
                    {!language.flag && <span class="inline-flex h-4 w-6 shrink-0 items-center justify-center rounded-sm bg-[rgba(243,88,40,0.09)] text-[0.68rem] font-bold text-[var(--color-text-muted)]">RU</span>}
                    <span>{localeNames[language.code]}</span>
                  </a>
                );
              })
            }
          </div>
        </div>
      </details>
      <a class="text-[0.95rem] text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]" href={`tel:${sharedContact.phones[0].replace(/\s+/g, "")}`}>{sharedContact.phones[0]}</a>
      <a class="inline-flex min-h-[2.55rem] min-w-[17rem] items-center justify-center rounded-full bg-[var(--color-primary)] px-6 py-2.5 text-center text-sm font-semibold text-white transition hover:bg-[var(--color-primary-dark)]" href={`${activePath}#contact`}>
        {data.header.consultationCta}
      </a>
    </div>

    <details class="relative lg:hidden">
      <summary class="grid w-11 list-none cursor-pointer gap-1 rounded-[0.8rem] border border-[var(--color-border)] px-2 py-2.5">
        <span class="block h-0.5 rounded-full bg-[var(--color-text)]"></span>
        <span class="block h-0.5 rounded-full bg-[var(--color-text)]"></span>
        <span class="block h-0.5 rounded-full bg-[var(--color-text)]"></span>
      </summary>
      <nav class="absolute right-0 top-[calc(100%+0.75rem)] grid w-[min(20rem,calc(100vw-2rem))] gap-4 rounded-2xl border border-[var(--color-border)] bg-white p-5 shadow-[var(--shadow-card)]" aria-label="Mobile">
        {data.header.navigation.map((item) => <a class="text-lg font-medium text-[var(--color-text)]" href={`${activePath}${item.href}`}>{item.name}</a>)}
        <details class="rounded-xl border border-[var(--color-border)]">
          <summary class="inline-flex min-h-[2.8rem] w-full list-none items-center justify-between px-4 text-sm font-medium text-[var(--color-text)]">
            <span>{localeNames[locale]}</span>
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M5.5 7.5 10 12l4.5-4.5" />
            </svg>
          </summary>
          <div class="grid gap-1 border-t border-[var(--color-border)] p-2" aria-label="Available languages">
            {
              languages.map((language) => (
                <a class="inline-flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-[var(--color-text-muted)] transition hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-text)]" href={localePaths[language.code]} aria-label={localeNames[language.code]}>
                  {language.flag === "bg" && (
                    <span class="inline-flex h-4 w-6 shrink-0 flex-col overflow-hidden rounded-sm border border-black/5">
                      <span class="h-1/3 w-full bg-white"></span>
                      <span class="h-1/3 w-full bg-[#1faa59]"></span>
                      <span class="h-1/3 w-full bg-[#d62612]"></span>
                    </span>
                  )}
                  {language.flag === "ua" && (
                    <span class="inline-flex h-4 w-6 shrink-0 flex-col overflow-hidden rounded-sm border border-black/5">
                      <span class="h-1/2 w-full bg-[#1f6fe5]"></span>
                      <span class="h-1/2 w-full bg-[#ffd84d]"></span>
                    </span>
                  )}
                  {!language.flag && <span class="inline-flex h-4 w-6 shrink-0 items-center justify-center rounded-sm bg-[rgba(243,88,40,0.09)] text-[0.68rem] font-bold text-[var(--color-text-muted)]">RU</span>}
                  <span>{localeNames[language.code]}</span>
                </a>
              ))
            }
          </div>
        </details>
        <a class="text-[0.95rem] text-[var(--color-text-muted)]" href={`tel:${sharedContact.phones[0].replace(/\s+/g, "")}`}>{sharedContact.phones[0]}</a>
        <a class="inline-flex min-h-[2.55rem] min-w-[17rem] items-center justify-center rounded-full bg-[var(--color-primary)] px-6 py-2.5 text-center text-sm font-semibold text-white" href={`${activePath}#contact`}>
          {data.header.consultationCta}
        </a>
      </nav>
    </details>
  </Container>
</header>
