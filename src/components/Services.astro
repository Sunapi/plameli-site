---
const services = [
  {
    marker: "AC",
    title: "Счетоводни услуги",
    description: "Пълно счетоводно обслужване, финансови отчети и управление, съобразени с българските изисквания.",
    features: ["Месечно счетоводство", "Финансови отчети", "Сверяване на сметки"],
  },
  {
    marker: "TX",
    title: "Данъчни консултации",
    description: "Експертни насоки за корпоративни и лични данъци, ДДС и стратегии за данъчна оптимизация.",
    features: ["Данъчно планиране", "Съответствие по ДДС", "Годишни декларации"],
  },
  {
    marker: "HR",
    title: "ТРЗ и личен състав",
    description: "Пълно администриране на заплати, трудови договори и социалноосигурителни задължения.",
    features: ["Изчисляване на заплати", "Осигуровки", "Трудови договори"],
  },
  {
    marker: "CR",
    title: "Регистрация на фирма",
    description: "Пълно съдействие при учредяване на дружество, регистрация и подготвяне на документи в България.",
    features: ["Учредяване на фирма", "Съдействие при регистрация", "Правни документи"],
  },
  {
    marker: "RP",
    title: "Отчетност и съответствие",
    description: "Навременно изготвяне и подаване на всички необходими отчети към българските институции.",
    features: ["Регулаторни отчети", "Проследяване на съответствие", "Подготовка за одит"],
  },
  {
    marker: "BS",
    title: "Бизнес подкрепа",
    description: "Стратегически консултации за компании на всеки етап - от стартиращи до утвърдени организации.",
    features: ["Бизнес консултиране", "Финансов анализ", "Стратегия за растеж"],
  },
];
---

<section class="section" id="services">
  <div class="container">
    <div class="section-heading section-heading-split">
      <div>
        <p class="eyebrow">Нашите услуги</p>
        <h2>Комплексни счетоводни и бизнес решения</h2>
        <p>
          От ежедневно счетоводство до стратегическо данъчно планиране, предлагаме
          пълния спектър от финансови услуги, необходими за развитието на вашия бизнес в България.
        </p>
      </div>
      <a class="button button-secondary" href="#contact">Обсъдете нуждите си</a>
    </div>
    <div class="card-grid card-grid-3">
      {
        services.map((service) => (
          <article class="service-card">
            <span class="feature-icon">{service.marker}</span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <ul class="service-list">
              {service.features.map((feature) => <li>{feature}</li>)}
            </ul>
            <a class="text-link" href="#contact">Научете повече</a>
          </article>
        ))
      }
    </div>
  </div>
</section>
