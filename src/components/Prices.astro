---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";

const pricingFactors = [
  {
    title: "Брой документи",
    description: "Получените и издадените фактури, банковите извлечения и останалите документи влияят върху цената на счетоводното обслужване.",
  },
  {
    title: "Вид дейност",
    description: "Услуги, търговия, производство, строителство и други специфики на бизнеса определят обхвата на необходимата работа.",
  },
  {
    title: "Обхват на дейността",
    description: "Работа в България, вътреобщностни доставки към ЕС, внос, износ и други операции се отчитат при формиране на цената.",
  },
  {
    title: "Регистрация по ЗДДС",
    description: "Наличието на регистрация по ЗДДС е един от факторите, които участват в ценообразуването.",
  },
  {
    title: "Персонал и обекти",
    description: "Броят на персонала и броят на обектите също влияят върху цената на предлаганите услуги.",
  },
  {
    title: "Гъвкава и прозрачна политика",
    description: "Ценовата ни политика е гъвкава, прозрачна и позволява на клиентите да оптимизират разходите си за счетоводни услуги.",
  },
];
---

<Section id="prices" size="base" class="border-t border-neutral-200/70 bg-white/65">
  <Container>
    <div class="mb-8 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading
        eyebrow="Цени"
        title="Как определяме цената"
        description="Ценовата ни политика е гъвкава, прозрачна и позволява на клиентите да оптимизират разходите си за счетоводни услуги. Цената на предлаганите от нас счетоводни услуги се определя в зависимост от конкретните параметри на бизнеса."
      />
      <a class="inline-flex self-start rounded-xl bg-orange-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-orange-600" href="#contact">
        Поискайте оферта
      </a>
    </div>

    <Grid class="gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        pricingFactors.map((factor) => (
          <Card as="article" class="flex h-full flex-col rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm">
            <h3 class="text-xl font-semibold text-[var(--color-text)]">{factor.title}</h3>
            <p class="mt-3 flex-grow text-sm leading-relaxed text-[var(--color-text-muted)]">{factor.description}</p>
          </Card>
        ))
      }
    </Grid>

    <p class="mt-8 text-lg leading-relaxed text-[var(--color-text-muted)]">
      Не се колебайте да се свържете с нас!
    </p>
  </Container>
</Section>
