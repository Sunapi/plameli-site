---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { localePaths, siteData, type Locale } from "../i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = siteData[locale].prices;
const basePath = localePaths[locale];
---

<Section id="prices" size="base" class="border-t border-neutral-200/70 bg-white/65">
  <Container>
    <div class="mb-8 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <SectionHeading eyebrow={data.eyebrow} title={data.title} description={data.description} />
      <a class="inline-flex self-start rounded-xl bg-orange-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-orange-600" href={`${basePath}#contact`}>
        {data.cta}
      </a>
    </div>

    <Grid class="gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {data.items.map((factor) => <Card as="article" class="flex h-full flex-col rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm"><h3 class="text-xl font-semibold text-[var(--color-text)]">{factor.title}</h3><p class="mt-3 flex-grow text-sm leading-relaxed text-[var(--color-text-muted)]">{factor.description}</p></Card>)}
    </Grid>

    <p class="mt-8 text-lg leading-relaxed text-[var(--color-text-muted)]">{data.footerNote}</p>
  </Container>
</Section>
