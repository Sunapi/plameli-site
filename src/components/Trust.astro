---
const trustPoints = [
  {
    marker: "PE",
    title: "Професионална експертиза",
    description: "Сертифицирани счетоводители с дълбоки познания по българското данъчно законодателство и международните стандарти.",
  },
  {
    marker: "PS",
    title: "Персонална подкрепа",
    description: "Специалист, посветен на вашия бизнес и на специфичните ви нужди.",
  },
  {
    marker: "FC",
    title: "Пълна конфиденциалност",
    description: "Вашите финансови данни са защитени чрез строги протоколи за поверителност и сигурни системи.",
  },
  {
    marker: "CC",
    title: "Ясна комуникация",
    description: "Обясняваме сложните регулации разбираемо. Консултации на български, украински и руски език.",
  },
  {
    marker: "LP",
    title: "Дългосрочно партньорство",
    description: "Развиваме се заедно с вашия бизнес и осигуряваме постоянна подкрепа на всеки етап.",
  },
  {
    marker: "RC",
    title: "Регулаторно съответствие",
    description: "Останете в крак с промените в законите и регулациите чрез навременни насоки.",
  },
];
---

<section class="section section-alt">
  <div class="container">
    <div class="section-heading section-heading-centered">
      <p class="eyebrow">Защо да изберете нас</p>
      <h2>Изградени върху доверие, работим с високо качество</h2>
      <p>
        Разбираме, че изборът на счетоводен партньор е решение, основано на доверие.
        Ето защо бизнеси от цяла България разчитат на нас.
      </p>
    </div>
    <div class="card-grid card-grid-3">
      {
        trustPoints.map((point) => (
          <article class="feature-card">
            <span class="feature-icon">{point.marker}</span>
            <h3>{point.title}</h3>
            <p>{point.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
