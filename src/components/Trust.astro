---
import Container from "./ui/Container.astro";
import Section from "./ui/Section.astro";
import Grid from "./ui/Grid.astro";
import Card from "./ui/Card.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { siteData, type Locale } from "../i18n/site";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const data = siteData[locale].trust;

const iconMap = {
  badge: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 5 6v6c0 4.2 2.7 7.7 7 9 4.3-1.3 7-4.8 7-9V6l-7-3Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="m9.5 12 1.7 1.7L14.8 10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  user: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM5 20a7 7 0 0 1 14 0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  lock: `<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="11" width="14" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M8 11V8a4 4 0 1 1 8 0v3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  chat: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 18 3 21V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H6Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M8 9h8M8 13h5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  handshake: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m7 12 3 3a2 2 0 0 0 2.8 0l4.2-4.2a2 2 0 0 1 2.8 0L21 12M3 10l4-4 4 4M5 18l2 2M9 16l2 2M13 14l2 2" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  scales: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4v16M6 7h12M9 20h6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="m7 7-3 5h6l-3-5Zm10 0-3 5h6l-3-5Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
};
---

<Section size="tight" class="bg-[var(--color-surface-muted)] pt-12 pb-10 lg:pt-16 lg:pb-14">
  <Container>
    <SectionHeading align="center" eyebrow={data.eyebrow} title={data.title} description={data.description} />
    <Grid class="mx-auto mt-10 max-w-5xl gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        data.points.map((point) => (
          <Card as="article" class="flex h-full flex-col transition hover:border-[var(--color-primary)]/20 hover:shadow-md">
            <span class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 text-[var(--color-primary)] [&_svg]:h-6 [&_svg]:w-6">
              <Fragment set:html={iconMap[point.icon]} />
            </span>
            <h3 class="text-lg font-semibold text-[var(--color-text)]">{point.title}</h3>
            <p class="mt-2 flex-grow text-sm leading-relaxed text-[var(--color-text-muted)]">{point.description}</p>
          </Card>
        ))
      }
    </Grid>
  </Container>
</Section>
