---
const benefits = [
  {
    title: "Спестете ценно време",
    description: "Освободете се от сложни счетоводни задачи и административна работа. Използвайте времето си за развитие на бизнеса.",
  },
  {
    title: "Намалете разходите",
    description: "Външното счетоводно обслужване често е по-икономично от поддържането на вътрешен счетоводен отдел.",
  },
  {
    title: "Без инвестиция в софтуер",
    description: "Работим с професионален счетоводен софтуер вместо вас - без нужда от скъпи лицензи и обучения.",
  },
  {
    title: "Достъп до специалисти",
    description: "Получавате подкрепа от екип квалифицирани счетоводители и данъчни експерти без допълнителни разходи по наемане.",
  },
  {
    title: "Фокус върху основната дейност",
    description: "Делегирайте финансовите задачи с увереност и се концентрирайте върху стратегическите си цели и растежа.",
  },
  {
    title: "Растете по-лесно",
    description: "Нашите услуги се адаптират към нуждите на вашия бизнес с развитието му, без сложността на разширяване на вътрешен екип.",
  },
];
---

<section class="section">
  <div class="container">
    <div class="section-heading section-heading-centered">
      <p class="eyebrow">Предимства</p>
      <h2>Защо да възложите счетоводството си външно?</h2>
      <p>
        Съвременните компании все по-често избират професионален счетоводен партньор вместо вътрешен екип.
        Ето как това може да бъде полезно за вашата организация.
      </p>
    </div>

    <div class="benefits-grid">
      {
        benefits.map((benefit, index) => (
          <article class="benefit-item">
            <span class="benefit-number">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{benefit.title}</h3>
              <p>{benefit.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
