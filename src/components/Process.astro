---
const steps = [
  {
    number: "01",
    title: "Начална консултация",
    description: "Започваме с безплатна консултация, за да разберем вашия бизнес, предизвикателства и цели. Възможна е на български, украински или руски език.",
  },
  {
    number: "02",
    title: "Анализ на нуждите",
    description: "Екипът ни анализира текущото ви състояние и определя конкретните услуги и подкрепа, от които имате нужда.",
  },
  {
    number: "03",
    title: "Индивидуална оферта",
    description: "Подготвяме персонализирано предложение с прозрачни цени и ясно описани услуги според вашите изисквания.",
  },
  {
    number: "04",
    title: "Плавно начало",
    description: "След одобрение организираме плавен преход. Получавате личен специалист и сигурен достъп до нашите системи.",
  },
  {
    number: "05",
    title: "Дългосрочно партньорство",
    description: "Получавате постоянна професионална подкрепа, навременни съвети и надеждно обслужване с развитието на вашия бизнес.",
  },
];
---

<section class="section" id="process">
  <div class="container">
    <div class="section-heading section-heading-centered">
      <p class="eyebrow">Как работим</p>
      <h2>Ясен и лесен път към финансова сигурност</h2>
      <p>
        Началото е лесно. Нашият структуриран процес осигурява плавен старт
        и създава основа за успешно дългосрочно партньорство.
      </p>
    </div>

    <div class="timeline">
      {
        steps.map((step) => (
          <article class="timeline-item">
            <span class="timeline-number">{step.number}</span>
            <div class="timeline-copy">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
